# Optional, but recommended for higher GitHub API rate limits.
GITHUB_TOKEN=

# AI provider. Any OpenAI-compatible /v1/chat/completions provider can be used.
# Examples: OpenAI, DeepSeek-compatible gateways, SiliconFlow, OpenRouter, or a private proxy.
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
# Use auto to discover available models from /v1/models.
# Set a concrete model id to switch manually after discovery.
AI_MODEL=auto
AI_MODEL_PREFERENCES=gpt-4.1-mini,gpt-4.1,gpt-4o-mini,gpt-4o,deepseek-chat,qwen-plus,qwen-turbo,glm-4-flash,moonshot-v1-8k

# Backward-compatible aliases. You can leave these empty if using AI_*.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Server Chan / Server Jiang send key.
# https://sct.ftqq.com/
SERVER_CHAN_SEND_KEY=

# Digest settings.
TRENDING_LANGUAGE=
PROJECT_LIMIT=10
README_CHARS=8000
FEATURE_POINT_COUNT=4
FEATURE_POINT_MAX_CHARS=90
SERVER_CHAN_PREVIEW_CHARS=1800
SEND_DRY_RUN=false
